{
  "name": "claude-sessions",
  "version": "0.1.0",
  "description": "A global TUI to find and resume any Claude Code session (ccs).",
  "type": "module",
  "bin": {
    "ccs": "bin/ccs"
  },
  "scripts": {
    "ccs": "bun run bin/ccs",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "setup": "bun run scripts/setup.ts",
    "lint:exports": "ts-prune -e",
    "lint:circular": "madge --circular --extensions ts,tsx src/"
  },
  "dependencies": {
    "fuzzysort": "^3.1.0",
    "ink": "^7.0.5",
    "react": "^19.2.6",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.15",
    "ink-testing-library": "^4.0.0",
    "madge": "^8.0.0",
    "ts-prune": "^0.10.3",
    "typescript": "^5"
  }
}
